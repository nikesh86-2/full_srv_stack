services:
  vpn:
    image: qmcgaw/gluetun:latest
    container_name: vpn
    cap_add:
      - NET_ADMIN
    devices:
      - /dev/net/tun:/dev/net/tun

    environment:
      - VPN_SERVICE_PROVIDER=${VPN_PROVIDER}
      - VPN_TYPE=wireguard

      - WIREGUARD_PRIVATE_KEY=${VPN_PRIVATE_KEY}
      - WIREGUARD_PRESHARED_KEY=${VPN_PRESHARED_KEY}
      - WIREGUARD_ADDRESSES=${VPN_ADDRESSES}
      - SERVER_REGIONS=${SERVER_REGIONS}
      - WIREGUARD_ENDPOINT_PORT=443
      - FIREWALL_VPN_INPUT_PORTS=${VPN_FIREWALL_INPUT_PORTS}
      - FIREWALL_OUTBOUND_SUBNETS=${VPN_FIREWALL_SUBNETS}
      - DNS_UPSTREAM_RESOLVER_TYPE=doh
      - DNS_UPSTREAM_RESOLVERS=cloudflare,google
      - BLOCK_MALICIOUS=off
      - BLOCK_SURVEILLANCE=off
      - BLOCK_ADS=off
      - WIREGUARD_MTU=1280
      - TZ=${TZ}
      - HEALTH_SUCCESS_WAIT=120s

    sysctls:
      - net.ipv6.conf.all.disable_ipv6=1

    volumes:
      - ${VPN_CONFIG_PATH}:/gluetun

    ports:
      - ${VPN_PORT_WEBUI}:8081
      - ${VPN_PORT_QB_1}:9696
      - ${VPN_PORT_SLSKD_TCP}:5030
      - ${VPN_PORT_SLSKD_SSL}:5031
      - ${FLARESOLVERR_PORT}:8191
      - 9050:9050
      - ${NEW_VPN_ENDPOINT_PORT}:${VPN_ENDPOINT_PORT}

    restart: unless-stopped

  slskd:
    image: slskd/slskd:latest
    container_name: slskd
    network_mode: "service:vpn"
    user: "${PUID}:${PGID}"

    environment:
      - SLSKD_UMASK=002
      - SLSKD_REMOTE_CONFIGURATION=true
      - SLSKD_USERNAME=${SLSKD_USERNAME}
      - SLSKD_PASSWORD=${SLSKD_PASSWORD}
      - SLSKD_SOULSEEK_USERNAME=${SLSKD_SOULSEEK_USERNAME}
      - SLSKD_SOULSEEK_PASSWORD=${SLSKD_SOULSEEK_PASSWORD}
      - SLSKD_API_KEY=${SLSKD_API_KEY}

    volumes:
      - ${SLSKD_CONFIG_PATH}:/app
      - ${DOWNLOADS_SOULSEEK}:/downloads
      - ${INCOMPLETE_SOULSEEK}:/incomplete

    restart: unless-stopped
    depends_on:
      - vpn

  soularr:
    image: mrusse08/soularr:latest
    container_name: soularr
    network_mode: "service:vpn"

    environment:
      - PYTHONUNBUFFERED=1
      - PUID=${PUID}
      - PGID=${PGID}
      - TZ=${TZ}
      - SCRIPT_INTERVAL=300

    volumes:
      - ${SOULARR_CONFIG_PATH}:/data
      - ${DOWNLOADS_SOULSEEK}:/downloads

    depends_on:
      - lidarr
      - slskd
      - vpn

    restart: unless-stopped

  qbittorrent:
    image: lscr.io/linuxserver/qbittorrent:latest
    container_name: qbittorrent
    network_mode: "service:vpn"

    environment:
      - PUID=${PUID}
      - PGID=${PGID}
      - UMASK=002
      - WEBUI_PORT=8081

    volumes:
      - ${QBIT_CONFIG_PATH}:/config
      - ${DOWNLOADS_TORRENTS}:/downloads

    restart: unless-stopped
    depends_on:
      - vpn

  lidarr:
    image: lscr.io/linuxserver/lidarr:latest
    container_name: lidarr
    networks:
      - media

    environment:
      - PUID=${PUID}
      - PGID=${PGID}
      - TZ=${TZ}

    volumes:
      - ${LIDARR_CONFIG_PATH}:/config
      - ${MEDIA_MUSIC}:/music
      - ${DOWNLOADS_SOULSEEK}:/downloads/soulseek
      - ${DOWNLOADS_TORRENTS}:/downloads/torrents

    ports:
      - ${LIDARR_PORT}:8686

    restart: unless-stopped

  prowlarr:
    image: lscr.io/linuxserver/prowlarr:latest
    container_name: prowlarr
    network_mode: "service:vpn"

    environment:
      - PUID=${PUID}
      - PGID=${PGID}
      - TZ=${TZ}

    volumes:
      - ${PROWLARR_CONFIG_PATH}:/config

    restart: unless-stopped

  sonarr:
    image: lscr.io/linuxserver/sonarr:latest
    container_name: sonarr
    networks:
      - media

    environment:
      - PUID=${PUID}
      - PGID=${PGID}
      - TZ=${TZ}

    volumes:
      - ${SONARR_CONFIG_PATH}:/config
      - ${MEDIA_TV}:/tv
      - ${DOWNLOADS_TV}:/downloads/tv

    ports:
      - ${SONARR_PORT}:8989

    restart: unless-stopped

  radarr:
    image: lscr.io/linuxserver/radarr:latest
    container_name: radarr
    networks:
      - media

    environment:
      - PUID=${PUID}
      - PGID=${PGID}
      - TZ=${TZ}

    volumes:
      - ${RADARR_CONFIG_PATH}:/config
      - ${MEDIA_MOVIES}:/movies
      - ${DOWNLOADS_MOVIES}:/downloads/movies

    ports:
      - ${RADARR_PORT}:7878

    restart: unless-stopped

  audiobookrequest:
    image: markbeep/audiobookrequest:latest
    container_name: audiobookrequest
    networks:
      - media

    environment:
      - PUID=${PUID}
      - PGID=${PGID}
      - TZ=${TZ}
      - ABR_APP__PORT=${ABR_PORT}

    volumes:
      - ${ABR_CONFIG_PATH}:/config
      - ${DOWNLOADS_AUDIOBOOKS}:/downloads

    ports:
      - ${ABR_PORT}:${ABR_PORT}

    restart: unless-stopped

  flaresolverr:
    image: ghcr.io/flaresolverr/flaresolverr:latest
    container_name: flaresolverr
    network_mode: "service:vpn"

    environment:
      - LOG_LEVEL=${LOG_LEVEL}
      - TZ=${TZ}

    restart: unless-stopped

  audiobookshelf:
    image: ghcr.io/advplyr/audiobookshelf:latest
    container_name: audiobookshelf

    environment:
      - TZ=${TZ}

    volumes:
      - ${AUDIOBOOKSHELF_CONFIG}:/config
      - ${AUDIOBOOKSHELF_METADATA}:/metadata
      - ${DOWNLOADS_AUDIOBOOKS}:/media/audiobooks
      - ${DOWNLOADS_PODCASTS}:/media/podcasts

    ports:
      - ${AUDIOBOOKSHELF_PORT}:80

    restart: unless-stopped

  jellyfin:
    image: jellyfin/jellyfin:latest
    container_name: jellyfin
    networks:
      - media

    environment:
      - PUID=${PUID}
      - PGID=${PGID}
      - TZ=${TZ}

    devices:
      - /dev/dri:/dev/dri

    volumes:
      - /mnt/jellyfin/jelly-config:/config
      - /mnt/jellyfin/jellyfin_cache:/cache
      - /mnt/jellyfin/jellyfin_log:/log
      - ${MEDIA_MUSIC}:/media/Music
      - ${MEDIA_MOVIES}:/media/Movies
      - ${MEDIA_TV}:/media/TV

    ports:
      - ${JELLYFIN_PORT}:8096

    restart: unless-stopped

networks:
  media:
    external: true
