# =========================================
# Docker User & Timezone
# =========================================
PUID=1000           # Docker user UID
PGID=1000           # Docker group GID
TZ=Europe/London    # Timezone

# =========================================
# VPN (WireGuard) Settings
# =========================================
VPN_PROVIDER=windscribe
VPN_PRIVATE_KEY=your_private_key_here
VPN_PRESHARED_KEY=your_preshared_key_here
VPN_ADDRESSES=0.0.0.0/32
VPN_ENDPOINT_PORT=443
VPN_FIREWALL_INPUT_PORTS=[VPN_INPUT_PORTS]
VPN_FIREWALL_SUBNETS=192.168.0.0/24,172.16.0.0/12,100.64.0.0/10

VPN_PORT_WEBUI=[WEBUI_PORT]
VPN_PORT_QB_1=[QBIT_PORT_1]
VPN_PORT_SLSKD_TCP=[SLSKD_TCP_PORT]
VPN_PORT_SLSKD_SSL=[SLSKD_SSL_PORT]

# =========================================
# Soulseek Credentials
# =========================================
SLSKD_USERNAME=your_username
SLSKD_PASSWORD=your_password
SLSKD_SOULSEEK_USERNAME=your_username
SLSKD_SOULSEEK_PASSWORD=your_password
SLSKD_API_KEY=your_api_key_here

# =========================================
# Config & Media Paths
# =========================================
VPN_CONFIG_PATH=/path/to/vpn-config
SLSKD_CONFIG_PATH=/path/to/slskd-config
SOULARR_CONFIG_PATH=/path/to/soularr-config
QBIT_CONFIG_PATH=/path/to/qbittorrent-config
LIDARR_CONFIG_PATH=/path/to/lidarr-config
PROWLARR_CONFIG_PATH=/path/to/prowlarr-config
SONARR_CONFIG_PATH=/path/to/sonarr-config
RADARR_CONFIG_PATH=/path/to/radarr-config
ABR_CONFIG_PATH=/path/to/abr-config
AUDIOBOOKSHELF_CONFIG=/path/to/audiobookshelf/config
AUDIOBOOKSHELF_METADATA=/path/to/audiobookshelf/metadata

DOWNLOADS_TORRENTS=/path/to/torrents
DOWNLOADS_SOULSEEK=/path/to/soulseek/downloads
INCOMPLETE_SOULSEEK=/path/to/soulseek/incomplete
DOWNLOADS_AUDIOBOOKS=/path/to/Audiobooks
DOWNLOADS_PODCASTS=/path/to/Podcasts
DOWNLOADS_TV=/path/to/tv
DOWNLOADS_MOVIES=/path/to/movies

MEDIA_MUSIC=/path/to/music
MEDIA_TV=/path/to/TV
MEDIA_MOVIES=/path/to/Movies

# =========================================
# App Ports
# =========================================
LIDARR_PORT=[LIDARR_PORT]
SONARR_PORT=[SONARR_PORT]
RADARR_PORT=[RADARR_PORT]
ABR_PORT=[ABR_PORT]
FLARESOLVERR_PORT=[FLARESOLVERR_PORT]
AUDIOBOOKSHELF_PORT=[AUDIOBOOKSHELF_PORT]
JELLYFIN_PORT=[JELLYFIN_PORT]

# =========================================
# Logging / Optional
# =========================================
LOG_LEVEL=info
